# Reckuit.ai Enterprise Configuration
# Copy this to .env for production deployment

# Server Configuration
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://app.reckuit.ai

# Security
JWT_SECRET=your_ultra_secure_jwt_secret_here
CANDIDATE_SECRET=your_candidate_portal_secret_here
ADMIN_API_KEY=your_internal_admin_key

# Database (MongoDB)
# MONGO_URL=mongodb://user:pass@host:27017/reckuit?authSource=admin
MONGO_URL=mongodb://localhost:27017/reckuit

# Messaging & Cache (Redis)
REDIS_URL=redis://localhost:6379

# LLM Providers (LiteLLM / Cloud)
# LiteLLM Proxy URL (Optional if using direct SDKs)
# LITELLM_PROXY_URL=http://localhost:4000
GROQ_API_KEY=gsk_your_key_here
OPENAI_API_KEY=sk-your_key_here

# Email Gateway (Resend)
RESEND_API_KEY=re_your_key_here
SYSTEM_EMAIL_FROM=notifications@reckuit.ai

# SSO / SAML (Optional Infrastructure)
# SAML_ENTRYPOINT=https://idp.ssoprovider.com/saml
# SAML_ISSUER=reckuit-ai-enterprise
